		"@types/react-dom": "^19.2.3",
		"@types/stats": "^0.16.30",
		"@types/three": "^0.182.0",
		"@vitejs/plugin-react": "^5.1.2",
		"electron": "40.1.0",
		"eslint": "^9.39.2",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.4.26",
		"globals": "^17.2.0",
		"prettier": "^3.8.1",
		"simple-git": "^3.30.0",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"vite-plugin-checker": "^0.12.0",
		"vite-plugin-svgr": "^4.5.0"
	},
	"scripts": {
		"start": "vite --host --port 3000",
		"build": "rm -rf dist && vite build && npm run generate-file-manifest && bash scripts/update-dist-dependencies.sh",
		"build-quick": "vite build",
		"eslint": "eslint ./src",
		"electron": "electron ./main.js",
		"build-electron": "npm run build-quick && npm run electron",
		"update-mods": "node scripts/update-mods.mjs",
		"generate-file-manifest": "node scripts/generate-file-manifest.mjs",
		"generate-plugins-manifest": "node scripts/generate-plugins-manifest.mjs",
		"update-packages": "npx npm-check-updates -u && rm -rf node_modules && npm install",
		"clear-packages": "rm -rf node_modules && rm package-lock.json && npm install",
		"update-version": "node scripts/update-version.mjs",
		"deploy-web": "bash scripts/deploy-web.sh prod",
		"countdown-web": "bash scripts/countdown-web.sh",
		"ssh": "bash scripts/ssh.sh",
		"tag-master-all": "bash scripts/tag-master-all.sh",
		"get-commits": "bash scripts/get-commits.sh",
		"generate-changelogs": "node scripts/generate-changelogs.mjs"
	},
	"browserslist": {
		"production": [
			">0.2%",
			"not dead",
			"not op_mini all",
			"not IE <= 11",
			"not Safari <= 8",
			"not Android <= 4.4"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	}
}
