		"react-i18next": "^16.5.4",
		"react-icons": "^5.5.0",
		"react-redux": "^9.2.0",
		"react-toastify": "^11.0.5",
		"three": "^0.182.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@types/howler": "^2.2.12",
		"@types/node": "^25.1.0",
