		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-i18next": "^17.0.3",
		"react-icons": "^5.6.0",
		"react-redux": "^9.2.0",
		"react-toastify": "^11.0.5",
		"three": "^0.183.2"
	},
	"devDependencies": {
		"@eslint/js": "9.39.2",
		"@types/howler": "^2.2.12",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/stats": "^0.16.30",
		"@types/three": "^0.183.1",
		"@vitejs/plugin-react": "^6.0.1",
		"electron": "41.2.0",
		"eslint": "9.39.4",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"globals": "^17.5.0",
		"prettier": "^3.8.3",
		"simple-git": "^3.36.0",
		"typescript": "~6.0.2",
		"typescript-eslint": "^8.58.2",
		"vite": "^8.0.8",
		"vite-plugin-checker": "^0.13.0",
		"vite-plugin-svgr": "^5.2.0"
	},
	"scripts": {
		"start": "vite --host --port 3000",
		"build": "rm -rf dist && npm run update-mods && vite build && npm run generate-file-manifest && npm run push-file-manifest && bash scripts/update-dist-dependencies.sh",
		"build-quick": "vite build",
		"eslint": "eslint ./src",
		"electron": "electron ./main.js",
		"build-electron": "npm run build-quick && npm run electron",
		"update-mods": "node scripts/update-mods.mjs",
		"generate-file-manifest": "node scripts/generate-file-manifest.mjs",
		"push-file-manifest": "bash scripts/push-file-manifest.sh",
		"generate-plugins-manifest": "node scripts/generate-plugins-manifest.mjs",
		"update-packages": "npx npm-check-updates -u && npm run clear-packages",
		"clear-packages": "rm -rf node_modules && rm package-lock.json && npm install",
		"update-version": "node scripts/update-version.mjs",
		"update-updater-version": "node scripts/update-updater-version.mjs",
		"deploy-web": "bash scripts/deploy-web.sh prod",
		"countdown-web": "bash scripts/countdown-web.sh",
		"ssh": "bash scripts/ssh.sh",
		"tag-master-all": "bash scripts/tag-master-all.sh",
		"get-commits": "bash scripts/get-commits.sh",
		"generate-changelogs": "node scripts/generate-changelogs.mjs"
	},
	"browserslist": {
		"production": [
			">0.2%",
			"not dead",
			"not op_mini all",
			"not IE <= 11",
			"not Safari <= 8",
			"not Android <= 4.4"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	}
}
